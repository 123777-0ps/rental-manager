# ============================================
# 演唱会手机租赁设备管理系统 - 本地部署配置
# ============================================
# 
# 使用方法：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 填写你的 Supabase 配置
# 3. 运行：pnpm install && pnpm dev
#
# 获取 Supabase 配置：
# 1. 注册 https://supabase.com 免费账号
# 2. 创建新项目
# 3. 在 Settings → API 中找到 URL 和 Key
# ============================================

# Supabase 项目 URL（必填）
SUPABASE_URL=https://你的项目ID.supabase.co

# Supabase 匿名密钥（必填）
SUPABASE_ANON_KEY=你的anon_key

# Supabase Service Role 密钥（必填，用于服务端读写数据）
SUPABASE_SERVICE_ROLE_KEY=你的service_role_key

# 服务端口（可选，默认5000）
PORT=5000
